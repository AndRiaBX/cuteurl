<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CuteURL — URL Shortener</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f0f4f8; color: #1a202c; min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 2rem 1rem; }
    .container { max-width: 720px; width: 100%; }
    h1 { font-size: 2rem; font-weight: 700; color: #2b6cb0; margin-bottom: .25rem; }
    p.sub { color: #718096; margin-bottom: 1.5rem; }
    .card { background: #fff; border-radius: 12px; padding: 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,.08); margin-bottom: 1.5rem; }
    .card h2 { font-size: 1.1rem; margin-bottom: .75rem; color: #2d3748; }
    form { display: flex; gap: .5rem; }
    form input[type="url"] { flex: 1; padding: .65rem .85rem; border: 2px solid #e2e8f0; border-radius: 8px; font-size: .95rem; outline: none; transition: border .15s; }
    form input[type="url"]:focus { border-color: #2b6cb0; }
    form button { padding: .65rem 1.25rem; background: #2b6cb0; color: #fff; border: none; border-radius: 8px; font-size: .95rem; font-weight: 600; cursor: pointer; transition: background .15s; }
    form button:hover { background: #1a4f7a; }
    .error { color: #e53e3e; background: #fff5f5; padding: .5rem .85rem; border-radius: 8px; margin-bottom: 1rem; font-size: .9rem; }
    .success { background: #f0fff4; color: #276749; padding: .5rem .85rem; border-radius: 8px; margin-bottom: 1rem; font-size: .9rem; display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
    .success a { color: #2b6cb0; font-weight: 600; text-decoration: none; }
    .success a:hover { text-decoration: underline; }
    table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    th, td { text-align: left; padding: .5rem .35rem; border-bottom: 1px solid #e2e8f0; }
    th { color: #718096; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; }
    td a { color: #2b6cb0; text-decoration: none; }
    td a:hover { text-decoration: underline; }
    .clicks { font-variant-numeric: tabular-nums; }
    .empty { text-align: center; color: #a0aec0; padding: 2rem 0; font-style: italic; }
    @media (max-width: 600px) { form { flex-direction: column; } }
  </style>
</head>
<body>
  <div class="container">
    <h1>CuteURL</h1>
    <p class="sub">Shorten long URLs into compact, shareable links.</p>

    <div class="card">
      <h2>Shorten a URL</h2>
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <% if (slug) { %>
        <div class="success">
          ✅ Short link: <a href="/<%= slug %>" target="_blank">/<%= slug %></a>
          &nbsp;→&nbsp; <code style="font-size:.8rem;word-break:break-all;color:#718096;" id="orig-display"></code>
        </div>
      <% } %>
      <form method="POST" action="/">
        <input type="url" name="url" placeholder="https://example.com/very/long/url" required autofocus>
        <button type="submit">Shorten</button>
      </form>
    </div>

    <div class="card">
      <h2>All Links</h2>
      <% if (links.length === 0) { %>
        <div class="empty">No links yet. Create your first one above.</div>
      <% } else { %>
        <table>
          <thead>
            <tr><th>Short</th><th>Original</th><th>Clicks</th><th>Created</th></tr>
          </thead>
          <tbody>
            <% links.forEach(l => { %>
              <tr>
                <td><a href="/<%= l.slug %>" target="_blank"><%= l.slug %></a></td>
                <td><a href="<%= l.original %>" target="_blank" style="display:inline-block;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= l.original %></a></td>
                <td class="clicks"><%= l.clicks %></td>
                <td><%= l.created_at %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>
